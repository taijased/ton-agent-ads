# ------------------------------------------------------------------------------
# App docs policy
# ------------------------------------------------------------------------------

# Keep task docs versioned by default
# apps/<app>/docs/<task>/README.md
# apps/<app>/docs/<task>/research.md
# apps/<app>/docs/<task>/plan/*.md
#
# But ignore runtime garbage inside docs folders.

apps/*/docs/