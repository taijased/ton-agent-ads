{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "lint": "pnpm --dir ../.. exec prettier --check \"packages/db/package.json\" \"packages/db/tsconfig.json\" \"packages/db/src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --eval \"console.log('No tests for @repo/db')\"",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@repo/types": "workspace:*",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
