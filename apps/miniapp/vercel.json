{
	"rewrites": [
		{
			"source": "/((?!tonconnect-manifest\\.json|icon\\.png|favicon\\.ico).*)",
			"destination": "/index.html"
		}
	],
	"headers": [
		{
			"source": "/tonconnect-manifest.json",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/json"
				},
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				},
				{
					"key": "Cache-Control",
					"value": "no-cache"
				}
			]
		},
		{
			"source": "/icon.png",
			"headers": [
				{
					"key": "Content-Type",
					"value": "image/png"
				},
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				}
			]
		}
	]
}