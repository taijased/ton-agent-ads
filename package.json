{
  "name": "ton-adagent",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "landing": "pnpm --filter @ton-adagent/landing dev",
    "miniapp": "pnpm --filter @ton-adagent/miniapp dev",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm exec prettier --check \"README.md\" \"apps/README.md\" \"package.json\" \"pnpm-workspace.yaml\" \"tsconfig.json\" && pnpm -r lint",
    "typecheck": "pnpm prisma:generate && pnpm -r typecheck",
    "test": "pnpm build && pnpm -r test",
    "build": "pnpm prisma:generate && pnpm -r build",
    "start": "pnpm --parallel --filter @repo/api --filter @repo/bot --filter @ton-adagent/miniapp --filter @ton-adagent/landing start",
    "opencode:check-version": "node scripts/check-opencode-version.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ton_adagent prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --name init --config prisma.config.ts",
    "prisma:seed": "prisma db seed --config prisma.config.ts",
    "tg:session": "tsx apps/bot/scripts/bootstrap-telegram-session.ts",
    "tg:check-session": "tsx apps/bot/scripts/check-telegram-session.ts",
    "tg:session-debug": "tsx apps/bot/scripts/debug-telegram-session.ts"
  },
  "devDependencies": {
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "prettier": "^3.5.3",
    "prisma": "^7.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "pg": "^8.20.0",
    "telegram": "^2.26.8"
  }
}
