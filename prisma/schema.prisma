generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id                  String               @id @default(uuid())
  userId              String
  text                String
  budgetAmount        String
  budgetCurrency      String               @default("TON")
  theme               String?
  tags                String[]             @default([])
  language            String?
  goal                String?
  ctaUrl              String?
  buttonText          String?
  mediaUrl            String?
  targetAudience      String?
  spent               Int                  @default(0)
  status              String
  negotiationStartedAt DateTime?
  negotiationStatus   String               @default("idle")
  createdAt           DateTime             @default(now())
  deals               Deal[]
  conversationThreads ConversationThread[]
}

model Channel {
  id                  String               @id
  username            String               @unique
  description         String?
  title               String
  category            String
  price               Int
  avgViews            Int
  adminParseStatus    String               @default("pending")
  readinessStatus     String               @default("unknown")
  adminCount          Int                  @default(0)
  lastParsedAt        DateTime?
  adminContacts       AdminContact[]
  deals               Deal[]
  contacts            ChannelContact[]
  conversationThreads ConversationThread[]
}

model AdminContact {
  id                  String               @id @default(uuid())
  channelId           String
  telegramHandle      String
  telegramUserId      String?
  source              String
  confidenceScore     Float
  status              String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  channel             Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversationThreads ConversationThread[]

  @@unique([channelId, telegramHandle])
}

model ChannelContact {
  id           String   @id @default(uuid())
  channelId    String
  type         String
  value        String
  source       String
  isAdsContact Boolean  @default(false)
  createdAt    DateTime @default(now())
  channel      Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, type, value])
}

model Deal {
  id         String   @id @default(uuid())
  campaignId String
  channelId  String
  price      Int
  status     String
  adminContactedAt DateTime?
  adminOutboundMessageId String?
  outreachError    String?
  termsAgreedAt    DateTime?
  paidAt           DateTime?
  proofText        String?
  proofUrl         String?
  completedAt      DateTime?
  failedAt         DateTime?
  lastCreatorNotificationAt DateTime?
  lastCreatorNotificationKey String?
  lastCreatorNotificationError String?
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Restrict)
  messages   DealMessage[]
  approvalRequests DealApprovalRequest[]
  externalThreads DealExternalThread[]

  @@unique([campaignId, channelId])
}

model DealMessage {
  id                String   @id @default(cuid())
  dealId            String
  direction         String
  senderType        String
  audience          String
  transport         String
  contactValue      String?
  text              String
  externalMessageId String?
  deliveryStatus    String?
  notificationKey   String?
  failureReason     String?
  createdAt         DateTime @default(now())
  deal              Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@unique([dealId, notificationKey])
  @@unique([dealId, senderType, externalMessageId])
}

model DealApprovalRequest {
  id               String   @id @default(cuid())
  dealId           String
  proposedPriceTon Float?
  proposedFormat   String?
  proposedDateText String?
  summary          String
  status           String
  createdAt        DateTime @default(now())
  resolvedAt       DateTime?
  deal             Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, status])
}

model DealExternalThread {
  id           String   @id @default(cuid())
  dealId       String
  platform     String
  chatId       String
  contactValue String?
  createdAt    DateTime @default(now())
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([platform, chatId])
}

model ConversationThread {
  id                  String                @id @default(uuid())
  campaignId          String
  channelId           String
  adminContactId      String
  status              String                @default("not_started")
  startedAt           DateTime?
  lastMessageAt       DateTime?
  lastMessagePreview  String?
  lastDirection       String?
  outreachAttemptCount Int                  @default(0)
  telegramChatId      String?               @unique
  closedAt            DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  campaign            Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel             Channel               @relation(fields: [channelId], references: [id], onDelete: Restrict)
  adminContact        AdminContact          @relation(fields: [adminContactId], references: [id], onDelete: Cascade)
  messages            ConversationMessage[]

  @@unique([campaignId, channelId, adminContactId])
  @@index([campaignId, updatedAt])
}

model ConversationMessage {
  id               String             @id @default(cuid())
  threadId         String
  direction        String
  messageType      String
  text             String
  telegramMessageId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  thread           ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@unique([threadId, telegramMessageId])
}
